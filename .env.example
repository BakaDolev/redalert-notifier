# Telegram API credentials — get from https://my.telegram.org
TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH=your_api_hash_here

# Group to monitor — username (without @) or numeric chat ID
TELEGRAM_GROUP=example_group_username

# n8n webhook URL
N8N_WEBHOOK_URL=http://localhost:5678/webhook/telegram-alerts

# Comma-separated keywords to match (Hebrew + English)
# Message must contain at least one keyword to be forwarded
KEYWORDS=השרון,שרון,נתניה,כפר יונה,מרכז,המרכז
